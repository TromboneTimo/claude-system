<?xml version="1.0" encoding="UTF-8"?>
<!-- Strict engraving style (Gould's Behind Bars / publisher-grade).
     Minimum clearances, tight but never colliding, aggressive re-flow. -->
<museScore version="3.01">
  <Style>
    <pageWidth>8.5</pageWidth>
    <pageHeight>11</pageHeight>
    <pagePrintableWidth>7.5</pagePrintableWidth>
    <pageEvenLeftMargin>0.5</pageEvenLeftMargin>
    <pageOddLeftMargin>0.5</pageOddLeftMargin>
    <pageEvenTopMargin>0.5</pageEvenTopMargin>
    <pageOddTopMargin>0.5</pageOddTopMargin>
    <pageEvenBottomMargin>0.75</pageEvenBottomMargin>
    <pageOddBottomMargin>0.75</pageOddBottomMargin>

    <staffUpperBorder>8</staffUpperBorder>
    <staffLowerBorder>8</staffLowerBorder>
    <staffDistance>8</staffDistance>
    <akkoladeDistance>7</akkoladeDistance>
    <minSystemDistance>10</minSystemDistance>
    <maxSystemDistance>16</maxSystemDistance>

    <lyricsPlacement>1</lyricsPlacement>
    <lyricsPosAbove x="0" y="-2"/>
    <lyricsPosBelow x="0" y="3"/>
    <lyricsMinTopDistance>2</lyricsMinTopDistance>
    <lyricsMinBottomDistance>2.5</lyricsMinBottomDistance>
    <lyricsLineHeight>1</lyricsLineHeight>

    <showMeasureNumber>1</showMeasureNumber>
    <measureNumberInterval>1</measureNumberInterval>
    <measureNumberSystem>1</measureNumberSystem>

    <minNoteDistance>1.4</minNoteDistance>
    <barNoteDistance>1.3</barNoteDistance>
    <noteBarDistance>1.3</noteBarDistance>
    <measureSpacing>1.75</measureSpacing>

    <beamWidth>0.5</beamWidth>
    <beamNoSlope>0</beamNoSlope>

    <stemWidth>0.13</stemWidth>

    <SlurMinDistance>0.75</SlurMinDistance>
    <MinTieLength>1.2</MinTieLength>

    <dynamicsPlacement>1</dynamicsPlacement>
    <dynamicsPosAbove x="0" y="-2.5"/>
    <dynamicsPosBelow x="0" y="3.5"/>
    <dynamicsMinDistance>1</dynamicsMinDistance>

    <hairpinPlacement>1</hairpinPlacement>
    <hairpinPosAbove x="0" y="-4"/>
    <hairpinPosBelow x="0" y="4"/>
    <hairpinHeight>1.2</hairpinHeight>

    <articulationMinDistance>0.75</articulationMinDistance>
    <articulationAnchorDefault>0</articulationAnchorDefault>

    <accidentalNoteDistance>0.25</accidentalNoteDistance>
    <accidentalDistance>0.35</accidentalDistance>

    <rehearsalMarkPlacement>0</rehearsalMarkPlacement>
    <rehearsalMarkPosAbove x="0" y="-4.5"/>
    <rehearsalMarkFrameType>1</rehearsalMarkFrameType>
    <rehearsalMarkFramePadding>0.75</rehearsalMarkFramePadding>

    <tempoPlacement>0</tempoPlacement>
    <tempoPosAbove x="0" y="-5"/>

    <createMultiMeasureRests>1</createMultiMeasureRests>
    <minEmptyMeasures>2</minEmptyMeasures>
    <minMMRestWidth>5</minMMRestWidth>

    <minMeasureWidth>6</minMeasureWidth>
  </Style>
</museScore>
