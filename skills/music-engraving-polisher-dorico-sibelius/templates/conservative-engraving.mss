<?xml version="1.0" encoding="UTF-8"?>
<!-- Conservative style: minimal changes, maximum preservation of the composer's
     explicit formatting choices. Applies only gentle spacing floors so no
     element physically overlaps another. -->
<museScore version="3.01">
  <Style>
    <pageWidth>8.5</pageWidth>
    <pageHeight>11</pageHeight>
    <pagePrintableWidth>7.7</pagePrintableWidth>

    <staffUpperBorder>7</staffUpperBorder>
    <staffLowerBorder>7</staffLowerBorder>
    <staffDistance>6.5</staffDistance>
    <akkoladeDistance>6.5</akkoladeDistance>
    <minSystemDistance>8.5</minSystemDistance>
    <maxSystemDistance>15</maxSystemDistance>

    <minNoteDistance>1.1</minNoteDistance>
    <barNoteDistance>1.1</barNoteDistance>
    <measureSpacing>1.3</measureSpacing>

    <dynamicsMinDistance>0.3</dynamicsMinDistance>
    <articulationMinDistance>0.3</articulationMinDistance>
    <accidentalDistance>0.22</accidentalDistance>

    <rehearsalMarkFramePadding>0.4</rehearsalMarkFramePadding>

    <minEmptyMeasures>2</minEmptyMeasures>
  </Style>
</museScore>