# Runtime / ephemeral - never track
.prompt_count
.session_meta
.gitignore_temp
history.jsonl
mcp-needs-auth-cache.json
stats-cache.json
settings.json

# Directories that are runtime state
backups/
cache/
debug/
file-history/
ide/
plans/
plugins/
# projects/ is runtime state (transcripts, tool-results, todos) -- ignored EXCEPT
# the per-project memory/ dirs (lessons, canon, project notes; scanned, no secrets)
# which we DO back up. (2026-06-24)
projects/*
!projects/*/
projects/*/*
!projects/*/memory/
sessions/
shell-snapshots/
statsig/
telemetry/
todos/
tools/

# Hooks are local-only (contain tokens in git remote)
hooks/

# SECRETS - never push to cloud (added 2026-06-22 before first full backup).
# credentials/MASTER.md holds live API keys/tokens/passwords. Belt-and-suspenders
# against any secret-shaped file anywhere in the tree.
credentials/
secrets/
**/.env
**/.env.*
!**/.env.example
**/*.pem
**/*.key
**/*.p12
**/MASTER.md
**/credentials.json
**/service-account*.json
auth-state.json
**/*.token
# Memory files that hold REAL credentials (e.g. Google OAuth GOCSPX secret in
# reference_google_api_credentials.md). Verified 2026-06-24; never back these up.
**/*credentials*.md
**/reference_google_api_credentials.md
